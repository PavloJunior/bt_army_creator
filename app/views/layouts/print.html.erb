<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= yield :title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: sans-serif; color: #333; }

    @page {
      size: A4 portrait;
      margin: 5mm;
    }

    .screen-only { display: block; }
    @media print { .screen-only { display: none !important; } }

    .print-header {
      padding: 1rem;
      margin-bottom: 1rem;
      border-bottom: 1px solid #ccc;
    }
    .print-header h1 { font-size: 1.25rem; margin-bottom: 0.25rem; }
    .print-header p { font-size: 0.85rem; color: #666; }
    .print-actions { margin-top: 0.75rem; display: flex; gap: 0.5rem; }
    .print-actions button, .print-actions a {
      padding: 0.5rem 1.5rem;
      border: 1px solid #333;
      background: #f5f5f5;
      color: #333;
      font-size: 0.85rem;
      text-decoration: none;
      cursor: pointer;
      border-radius: 3px;
    }
    .print-actions button:hover, .print-actions a:hover {
      background: #e0e0e0;
    }

    .card-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2mm;
      padding: 0 2mm;
    }
    .card-grid img {
      width: 100%;
      height: auto;
      display: block;
    }
    .card-cell {
      break-inside: avoid;
    }
    .card-placeholder {
      aspect-ratio: 3.5 / 2.5;
      background: #e0e0e0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #999;
      font-size: 0.8rem;
      border: 1px dashed #ccc;
    }
  </style>
</head>
<body>
  <%= yield %>
</body>
</html>
