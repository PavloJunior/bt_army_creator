<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "BT Army Creator" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 min-h-screen">
    <header class="bg-gray-900 text-white">
      <div class="container mx-auto px-6 py-4 flex justify-between items-center">
        <%= link_to root_path, class: "text-xl font-bold hover:text-gray-300 transition" do %>
          BT Army Creator
        <% end %>
        <% if authenticated? %>
          <div class="flex items-center gap-4">
            <%= link_to "Admin", admin_root_path, class: "text-gray-300 hover:text-white text-sm" %>
            <%= button_to "Wyloguj się", admin_session_path, method: :delete,
                class: "text-gray-400 hover:text-white text-sm" %>
          </div>
        <% end %>
      </div>
    </header>

    <main class="container mx-auto px-6 py-8">
      <% if flash[:notice] %>
        <div class="mb-6 p-4 bg-green-100 border border-green-300 text-green-800 rounded-lg">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="mb-6 p-4 bg-red-100 border border-red-300 text-red-800 rounded-lg">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
