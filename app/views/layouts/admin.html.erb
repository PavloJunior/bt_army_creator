<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin - BT Army Creator" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-hud-bg min-h-screen font-hud-mono text-hud-text">
    <div class="hud-scanlines" aria-hidden="true"></div>
    <div class="hud-grid" aria-hidden="true"></div>

    <div class="flex min-h-screen relative z-10">
      <!-- Sidebar -->
      <aside class="w-64 bg-hud-bg-panel border-r border-hud-border-bright flex-shrink-0 flex flex-col">
        <div class="p-6">
          <h1 class="font-hud-heading text-xl font-bold tracking-wider uppercase text-hud-green hud-glow">BT Army Creator</h1>
          <p class="text-hud-amber text-sm mt-1 uppercase tracking-wider">Admin</p>
        </div>
        <nav class="mt-2 flex-1">
          <%= link_to "Dashboard", admin_root_path,
              class: "block px-6 py-3 transition #{request.path == admin_root_path ? 'bg-hud-green/10 text-hud-green border-r-2 border-hud-green' : 'text-hud-text-muted hover:bg-hud-bg-panel-hover hover:text-hud-green'}" %>
          <%= link_to "Chassis", admin_chassis_index_path,
              class: "block px-6 py-3 transition #{request.path.start_with?('/admin/chassis') ? 'bg-hud-green/10 text-hud-green border-r-2 border-hud-green' : 'text-hud-text-muted hover:bg-hud-bg-panel-hover hover:text-hud-green'}" %>
          <%= link_to "MUL Sync", admin_sync_attempts_path,
              class: "block px-6 py-3 transition #{request.path.start_with?('/admin/sync_attempts') ? 'bg-hud-green/10 text-hud-green border-r-2 border-hud-green' : 'text-hud-text-muted hover:bg-hud-bg-panel-hover hover:text-hud-green'}" %>
          <%= link_to "Events", admin_events_path,
              class: "block px-6 py-3 transition #{request.path.start_with?('/admin/events') ? 'bg-hud-green/10 text-hud-green border-r-2 border-hud-green' : 'text-hud-text-muted hover:bg-hud-bg-panel-hover hover:text-hud-green'}" %>
          <%= link_to "Jobs", "/admin/jobs",
              class: "block px-6 py-3 transition #{request.path.start_with?('/admin/jobs') ? 'bg-hud-green/10 text-hud-green border-r-2 border-hud-green' : 'text-hud-text-muted hover:bg-hud-bg-panel-hover hover:text-hud-green'}" %>
        </nav>
        <div class="p-6 border-t border-hud-border">
          <%= button_to "Sign Out", admin_session_path, method: :delete,
              class: "text-hud-text-muted hover:text-hud-red transition text-sm uppercase tracking-wider cursor-pointer bg-transparent" %>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-8">
        <% if flash[:notice] %>
          <div class="mb-6 p-4 bg-hud-bg-panel border border-hud-green text-hud-green rounded text-sm hud-panel">
            <span class="text-hud-text-muted uppercase text-xs tracking-wider">System</span>
            <p class="mt-1"><%= flash[:notice] %></p>
          </div>
        <% end %>
        <% if flash[:alert] %>
          <div class="mb-6 p-4 bg-hud-bg-panel border border-hud-red text-hud-red rounded text-sm">
            <span class="text-hud-amber uppercase text-xs tracking-wider">Warning</span>
            <p class="mt-1"><%= flash[:alert] %></p>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
