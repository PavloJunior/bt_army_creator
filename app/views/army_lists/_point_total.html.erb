<div id="point_total" class="text-right">
  <% total = army_list.total_points %>
  <% cap = event.point_cap %>
  <% percentage = cap > 0 ? (total.to_f / cap * 100).clamp(0, 100) : 0 %>
  <% over_cap = total > cap %>
  <%# Readout text color shifts with percentage %>
  <% color_class = if over_cap
                     'text-hud-red'
                   elsif percentage >= 90
                     'text-hud-red'
                   elsif percentage >= 70
                     'text-hud-amber'
                   else
                     'text-hud-green'
                   end %>

  <div class="flex items-center justify-end gap-3">
    <div class="text-right">
      <div class="text-[9px] text-hud-text-muted uppercase tracking-wider">
        <%= event.point_value_label.upcase %> Capacity
      </div>
      <div class="text-xs text-hud-text-dim">
        <%= total %> / <%= cap %>
      </div>
    </div>
    <div class="hud-gauge-track rounded-sm" style="<%= 'border-color: var(--color-hud-red); box-shadow: 0 0 8px var(--color-hud-red-glow);' if over_cap %>">
      <%# Heat gauge: green → yellow at 50% → orange at 75% → red at 90%.
          Each threshold maps to a position within the bar's own coordinate space. %>
      <% if percentage <= 50
           gradient = '#00ff41'
         elsif percentage <= 75
           # 50-75%: green with yellow creeping in at the tip
           p50 = (50.0 / percentage * 100).round
           gradient = "linear-gradient(90deg, #00ff41 0%, #00ff41 #{p50}%, #ffaa00 100%)"
         elsif percentage <= 90
           # 75-90%: green → yellow midpoint → orange at the tip
           p50 = (50.0 / percentage * 100).round
           p75 = (75.0 / percentage * 100).round
           gradient = "linear-gradient(90deg, #00ff41 0%, #00ff41 #{p50}%, #ffaa00 #{p75}%, #ff6622 100%)"
         else
           # 90-100%: green → yellow → orange → red at the tip
           p50 = (50.0 / percentage * 100).round
           p75 = (75.0 / percentage * 100).round
           p90 = (90.0 / percentage * 100).round
           gradient = "linear-gradient(90deg, #00ff41 0%, #00ff41 #{p50}%, #ffaa00 #{p75}%, #ff6622 #{p90}%, #ff4444 100%)"
         end %>
      <div class="hud-gauge-fill" style="width: <%= percentage %>%; background: <%= gradient %>;"></div>
      <div class="hud-gauge-ticks"></div>
    </div>
    <div class="hud-gauge-readout <%= color_class %>" style="<%= 'text-shadow: 0 0 10px var(--color-hud-red-glow);' if over_cap %>">
      <%= total %>
    </div>
  </div>
  <% if over_cap %>
    <p class="text-xs text-hud-red mt-1">PRZEKROCZONO LIMIT PUNKTÓW!</p>
  <% end %>
</div>
