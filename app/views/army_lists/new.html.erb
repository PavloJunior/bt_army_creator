<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">Utwórz listę armijną</h1>
  <p class="text-gray-500 mb-6"><%= @event.name %> &middot; <%= @event.game_system_label %> &middot; <%= @event.point_cap %> <%= @event.point_value_label %></p>

  <div class="bg-white rounded-lg shadow p-6">
    <%= form_with model: [@event, @army_list], class: "space-y-4" do |form| %>
      <% if @army_list.errors.any? %>
        <div class="p-4 bg-red-100 border border-red-300 text-red-800 rounded-lg">
          <ul class="list-disc list-inside">
            <% @army_list.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :player_name, "Twoje imię", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :player_name, required: true, autofocus: true,
            placeholder: "Wpisz swoje imię",
            class: "w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="flex gap-3">
        <%= form.submit "Rozpocznij budowanie",
            class: "px-6 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition cursor-pointer" %>
        <%= link_to "Anuluj", event_path(@event),
            class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition" %>
      </div>
    <% end %>
  </div>
</div>
