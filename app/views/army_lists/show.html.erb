<%= turbo_stream_from "event_#{@event.id}_miniatures" %>
<% content_for(:status_context) { "BUDOWANIE LISTY // #{@army_list.player_name.upcase}" } %>

<div class="max-w-7xl mx-auto">
  <%# Army Status Banner %>
  <div class="bg-hud-bg-panel border border-hud-border rounded p-5 mb-6 hud-panel hud-blueprint-grid hud-watermark-mech">
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4">
      <div>
        <h1 class="font-hud-heading text-2xl font-bold text-hud-green hud-glow uppercase">
          <%= @army_list.player_name %>
        </h1>
        <div class="text-hud-text-dim mt-1 text-sm flex flex-wrap items-center gap-x-1 gap-y-1">
          <span><%= @event.name %> · <%= @event.game_system_label %> ·</span>
          <% if @is_owner && @army_list.draft? %>
            <%= form_with url: change_tech_base_event_army_list_path(@event, @army_list),
                method: :patch,
                class: "inline-flex items-center gap-1",
                data: { controller: "tech-base", tech_base_original_value: @army_list.tech_base } do %>
              <%= select_tag :tech_base,
                  options_for_select(
                    [["Inner Sphere", "inner_sphere"], ["Clan", "clan"], ["Mixed", "mixed"]],
                    @army_list.tech_base
                  ),
                  class: "hud-select text-sm px-2 py-0.5 rounded",
                  data: { tech_base_target: "select", action: "change->tech-base#change" } %>
            <% end %>
          <% else %>
            <span><%= @army_list.tech_base_label %></span>
          <% end %>
        </div>
      </div>
      <%= render partial: "army_lists/point_total", locals: { army_list: @army_list, event: @event } %>
    </div>
    <div class="hud-hazard-stripe mt-4 -mx-5 -mb-5 rounded-b"></div>
  </div>

  <%# Submitted banner %>
  <% if @army_list.submitted? %>
    <div class="mb-6 p-4 bg-hud-bg-panel border border-hud-green text-hud-green rounded text-sm hud-panel">
      <span class="hud-stamp hud-stamp-green mr-3">Zgłoszona</span>
      Lista zgłoszona <%= I18n.l(@army_list.submitted_at, format: :long) %>. Modele są zablokowane na to wydarzenie.
    </div>
  <% end %>

  <%# Tabbed interface (draft only) %>
  <% unless @army_list.submitted? %>
    <div class="lg:grid lg:grid-cols-[260px_1fr] lg:gap-6">
    <%# Faction Sidebar %>
    <aside class="hidden lg:block">
      <%= render "army_lists/faction_sidebar",
          sidebar_factions: @sidebar_factions,
          selected_faction_mul_ids: @selected_faction_mul_ids,
          event: @event,
          army_list: @army_list %>
    </aside>

    <div>
    <div data-controller="tab-switch" data-tab-switch-default-value="army">
      <div class="flex border-b border-hud-border mb-0">
        <button class="hud-tab"
                data-tab-switch-target="tab"
                data-action="tab-switch#switch"
                data-tab-switch-name-param="army">
          Twoja Armia (<span id="army_item_count"><%= @items.size %></span>)
        </button>
        <button class="hud-tab"
                data-tab-switch-target="tab"
                data-action="tab-switch#switch"
                data-tab-switch-name-param="browser">
          Dostępne Jednostki
        </button>
      </div>

      <%# Army Panel %>
      <div data-tab-switch-target="panel" data-tab-name="army" class="pt-4">
        <div id="army_list_items" class="space-y-3 hud-dashed-divider-list">
          <% @items.each do |item| %>
            <%= render partial: "army_list_items/item",
                locals: { item: item, event: @event, army_list: @army_list, is_owner: @is_owner } %>
          <% end %>
        </div>

        <% if @items.empty? %>
          <div id="army_list_empty_state"
               class="bg-hud-bg-panel border border-hud-border rounded p-6 text-center text-hud-text-muted">
            <p>Brak jednostek. Przełącz na zakładkę "Dostępne Jednostki" aby dodać modele.</p>
          </div>
        <% end %>

        <%= render partial: "army_lists/actions",
            locals: { army_list: @army_list, event: @event, is_owner: @is_owner } %>
      </div>

      <%# Browser Panel %>
      <div data-tab-switch-target="panel" data-tab-name="browser" class="hidden pt-4">
        <%# Mobile faction filter %>
        <div class="lg:hidden mb-4">
          <div class="bg-hud-bg-panel border border-hud-border rounded p-3">
            <h3 class="text-xs text-hud-text-muted uppercase tracking-wider mb-2 font-hud-heading">Podfrakcja</h3>
            <div class="flex flex-wrap gap-1.5">
              <% @sidebar_factions.each do |_category, factions| %>
                <% factions.each do |faction| %>
                  <% selected = @selected_faction_mul_ids.include?(faction.mul_id) %>
                  <%= form_with url: toggle_faction_event_army_list_path(@event, @army_list),
                      method: :patch,
                      class: "inline",
                      data: { turbo: false,
                              controller: "faction-toggle",
                              faction_toggle_has_conflicts_value: false } do |f| %>
                    <%= f.hidden_field :faction_mul_id, value: faction.mul_id %>
                    <button type="submit"
                            data-action="faction-toggle#toggle"
                            class="px-2 py-0.5 text-xs rounded transition cursor-pointer
                                   <%= if selected
                                         'text-hud-green bg-hud-green/10 border border-hud-green/40'
                                       else
                                         'text-hud-text-dim hover:text-hud-green border border-hud-border'
                                       end %>">
                      <%= faction.name %>
                    </button>
                  <% end %>
                <% end %>
              <% end %>
              <% if @selected_faction_mul_ids.any? %>
                <%= button_to toggle_faction_event_army_list_path(@event, @army_list),
                    method: :patch,
                    params: { clear_all: "true" },
                    class: "px-2 py-0.5 text-xs rounded transition cursor-pointer
                           text-hud-amber hover:text-hud-amber border border-hud-amber/40",
                    form: { data: { turbo: false } } do %>
                  Wyczyść
                <% end %>
              <% end %>
            </div>
          </div>
        </div>

        <div id="available_miniatures" class="grid gap-4 md:grid-cols-2">
          <% faction_filter = @selected_faction_mul_ids.presence %>
          <% @chassis_data.each do |chassis, available_count, total_count| %>
            <% variants = @event.available_variants_for_chassis(chassis, tech_base: @army_list.tech_base, faction_mul_ids: faction_filter) %>
            <% next if variants.empty? && available_count > 0 %>
            <%= render partial: "chassis/available_card", locals: {
              chassis: chassis, available_count: available_count, total_count: total_count,
              variants: variants, event: @event, army_list: @army_list
            } %>
          <% end %>
        </div>

        <% if @chassis_data.empty? %>
          <div class="bg-hud-bg-panel border border-hud-border rounded p-6 text-center text-hud-text-muted">
            <p>Brak dostępnych modeli.</p>
          </div>
        <% end %>
      </div>
    </div>
    </div><%# /main content wrapper %>
    </div><%# /grid %>
  <% else %>
    <%# Submitted: army only, no tabs %>
    <div id="army_list_items" class="space-y-3 hud-dashed-divider-list">
      <% @items.each do |item| %>
        <%= render partial: "army_list_items/item",
            locals: { item: item, event: @event, army_list: @army_list, is_owner: @is_owner } %>
      <% end %>
    </div>
  <% end %>
</div>

<div id="add_unit_errors"></div>
