<%= turbo_stream_from "event_#{@event.id}_miniatures" %>
<% content_for(:status_context) { "BUDOWANIE LISTY // #{@army_list.player_name.upcase}" } %>
<%= specials_data_tag %>

<div class="max-w-6xl mx-auto">
  <%# Army Status Banner %>
  <div class="bg-hud-bg-panel border border-hud-border rounded p-5 mb-6 hud-panel hud-blueprint-grid hud-watermark-mech">
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4">
      <div>
        <h1 class="font-hud-heading text-2xl font-bold text-hud-green hud-glow uppercase">
          <%= @army_list.player_name %>
        </h1>
        <div class="text-hud-text-dim mt-1 text-sm flex flex-wrap items-center gap-x-1 gap-y-1">
          <span><%= @event.name %> · <%= @event.game_system_label %> ·</span>
          <% if @is_owner && @army_list.draft? %>
            <%= form_with url: change_tech_base_event_army_list_path(@event, @army_list),
                method: :patch,
                class: "inline-flex items-center gap-1",
                data: { controller: "tech-base", tech_base_original_value: @army_list.tech_base } do %>
              <%= select_tag :tech_base,
                  options_for_select(
                    [["Inner Sphere", "inner_sphere"], ["Clan", "clan"], ["Mixed", "mixed"]],
                    @army_list.tech_base
                  ),
                  class: "hud-select text-sm px-2 py-0.5 rounded",
                  data: { tech_base_target: "select", action: "change->tech-base#change" } %>
            <% end %>
          <% else %>
            <span><%= @army_list.tech_base_label %></span>
          <% end %>
        </div>
      </div>
      <%= render partial: "army_lists/point_total", locals: { army_list: @army_list, event: @event } %>
    </div>
    <div class="hud-hazard-stripe mt-4 -mx-5 -mb-5 rounded-b"></div>
  </div>

  <%# Submitted banner %>
  <% if @army_list.submitted? %>
    <div class="mb-6 p-4 bg-hud-bg-panel border border-hud-green text-hud-green rounded text-sm hud-panel">
      <span class="hud-stamp hud-stamp-green mr-3">Zgłoszona</span>
      Lista zgłoszona <%= I18n.l(@army_list.submitted_at, format: :long) %>. Modele zostały zarezerwowane na tę bitwę.
    </div>
    <% if @event.game_system == "alpha_strike" %>
      <div class="mb-6">
        <a class="inline-block hud-btn-primary px-6 py-3 rounded text-sm no-underline"
           data-controller="print-ready"
           data-print-ready-url-value="<%= print_cards_ready_event_army_list_path(@event, @army_list) %>"
           data-print-ready-print-url-value="<%= print_cards_event_army_list_path(@event, @army_list) %>"
           disabled
           style="pointer-events: none; opacity: 0.5;">
          Przygotowywanie kart...
        </a>
      </div>
    <% end %>
  <% end %>

  <%# Inactive banner %>
  <% if @army_list.inactive? %>
    <div class="mb-6 p-4 bg-hud-bg-panel border border-hud-border text-hud-text-muted rounded text-sm hud-panel">
      <span class="hud-stamp hud-stamp-muted mr-3">Nieaktywna</span>
      Lista jest nieaktywna. Modele nie są zarezerwowane.
    </div>
  <% end %>

  <%# Tabbed interface (draft only) %>
  <% if @army_list.draft? %>
    <div class="lg:grid lg:grid-cols-[260px_1fr] lg:gap-6">
    <%# Faction Sidebar %>
    <aside class="hidden lg:block">
      <%= render "army_lists/faction_sidebar",
          sidebar_factions: @sidebar_factions,
          selected_faction_mul_ids: @selected_faction_mul_ids,
          event: @event,
          army_list: @army_list %>
    </aside>

    <div>
    <div data-controller="tab-switch" data-tab-switch-default-value="browser">
      <div class="flex border-b border-hud-border mb-0">
        <button class="hud-tab"
                data-tab-switch-target="tab"
                data-action="tab-switch#switch"
                data-tab-switch-name-param="army">
          Twoja Armia (<span id="army_item_count"><%= @items.size %></span>)
        </button>
        <button class="hud-tab"
                data-tab-switch-target="tab"
                data-action="tab-switch#switch"
                data-tab-switch-name-param="browser">
          Dostępne Jednostki
        </button>
      </div>

      <%# Army Panel %>
      <div data-tab-switch-target="panel" data-tab-name="army" class="pt-4">
        <div id="army_list_items" class="space-y-3 hud-dashed-divider-list">
          <% @items.each do |item| %>
            <%= render partial: "army_list_items/item",
                locals: { item: item, event: @event, army_list: @army_list, is_owner: @is_owner } %>
          <% end %>
        </div>

        <% if @items.empty? %>
          <div id="army_list_empty_state"
               class="bg-hud-bg-panel border border-hud-border rounded p-6 text-center text-hud-text-muted">
            <p>Brak jednostek. Przełącz na zakładkę "Dostępne Jednostki" aby dodać modele.</p>
          </div>
        <% end %>

        <%= render partial: "army_lists/actions",
            locals: { army_list: @army_list, event: @event, is_owner: @is_owner } %>
      </div>

      <%# Browser Panel %>
      <div data-tab-switch-target="panel" data-tab-name="browser" class="hidden pt-4"
           data-controller="unit-type-filter chassis-browser"
           data-chassis-browser-point-cap-value="<%= @event.point_cap %>"
           data-chassis-browser-army-list-id-value="<%= @army_list.id %>">
        <%# Mobile faction filter %>
        <div class="lg:hidden mb-4">
          <div class="bg-hud-bg-panel border border-hud-border rounded p-3 space-y-3">
            <div>
              <h3 class="text-xs text-hud-text-muted uppercase tracking-wider mb-2 font-hud-heading">Podfrakcja</h3>
              <div class="flex flex-wrap gap-1.5">
                <% @sidebar_factions.each do |_category, factions| %>
                  <% factions.each do |faction| %>
                    <% selected = @selected_faction_mul_ids.include?(faction.mul_id) %>
                    <%= form_with url: toggle_faction_event_army_list_path(@event, @army_list),
                        method: :patch,
                        class: "inline",
                        data: { turbo: false,
                                controller: "faction-toggle",
                                faction_toggle_has_conflicts_value: false } do |f| %>
                      <%= f.hidden_field :faction_mul_id, value: faction.mul_id %>
                      <button type="submit"
                              data-action="faction-toggle#toggle"
                              class="px-2 py-0.5 text-xs rounded transition cursor-pointer
                                     <%= if selected
                                           'text-hud-green bg-hud-green/10 border border-hud-green/40'
                                         else
                                           'text-hud-text-dim hover:text-hud-green border border-hud-border'
                                         end %>">
                        <%= faction.name %>
                      </button>
                    <% end %>
                  <% end %>
                <% end %>
                <% if @selected_faction_mul_ids.any? %>
                  <%= button_to toggle_faction_event_army_list_path(@event, @army_list),
                      method: :patch,
                      params: { clear_all: "true" },
                      class: "px-2 py-0.5 text-xs rounded transition cursor-pointer
                             text-hud-amber hover:text-hud-amber border border-hud-amber/40",
                      form: { data: { turbo: false } } do %>
                    Wyczyść
                  <% end %>
                <% end %>
              </div>
            </div>
            <% if @available_unit_types.size > 1 %>
              <div>
                <h3 class="text-xs text-hud-text-muted uppercase tracking-wider mb-2 font-hud-heading">Typ jednostki</h3>
                <div class="flex flex-wrap gap-1.5">
                  <button class="hud-filter-btn px-2 py-0.5 text-xs rounded cursor-pointer border"
                          data-unit-type-filter-target="button"
                          data-unit-type="all"
                          data-action="unit-type-filter#filter">
                    Wszystkie
                  </button>
                  <% @available_unit_types.each do |unit_type| %>
                    <button class="hud-filter-btn px-2 py-0.5 text-xs rounded cursor-pointer border"
                            data-unit-type-filter-target="button"
                            data-unit-type="<%= unit_type %>"
                            data-action="unit-type-filter#filter">
                      <%= unit_type %>
                    </button>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div data-controller="view-toggle">
          <div class="flex flex-wrap justify-between items-center mb-3 gap-2">
            <% if @available_unit_types.size > 1 %>
              <div class="hidden lg:flex flex-wrap gap-1">
                <button class="hud-filter-btn text-xs px-2 py-1 rounded cursor-pointer border"
                        data-unit-type-filter-target="button"
                        data-unit-type="all"
                        data-action="unit-type-filter#filter">
                  Wszystkie
                </button>
                <% @available_unit_types.each do |unit_type| %>
                  <button class="hud-filter-btn text-xs px-2 py-1 rounded cursor-pointer border"
                          data-unit-type-filter-target="button"
                          data-unit-type="<%= unit_type %>"
                          data-action="unit-type-filter#filter">
                    <%= unit_type %>
                  </button>
                <% end %>
              </div>
            <% end %>

            <div class="flex gap-1 ml-auto">
              <button class="hud-filter-btn text-xs px-2 py-1 rounded cursor-pointer border"
                      data-view-toggle-target="listButton"
                      data-action="view-toggle#list">
                &#9776; Lista
              </button>
              <button class="hud-filter-btn text-xs px-2 py-1 rounded cursor-pointer border"
                      data-view-toggle-target="gridButton"
                      data-action="view-toggle#grid">
                &#8862; Siatka
              </button>
              <button class="hud-filter-btn text-xs px-2 py-1 rounded cursor-pointer border"
                      data-chassis-browser-target="toggleButton"
                      data-action="chassis-browser#togglePanel">
                &#9660; Filtry <span data-chassis-browser-target="badge"
                                     class="ml-1 hidden text-[10px] bg-hud-green/20 text-hud-green px-1.5 py-0.5 rounded-full"></span>
              </button>
            </div>
          </div>

          <div data-chassis-browser-target="panel" class="hidden mb-3 bg-hud-bg-panel border border-hud-border rounded p-3">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="text-[10px] text-hud-text-muted uppercase tracking-wider block mb-1 font-hud-heading">Sortowanie</label>
                <select data-chassis-browser-target="sortSelect"
                        data-action="change->chassis-browser#sort"
                        class="w-full px-2 py-1 text-xs rounded hud-select">
                  <option value="name-asc">Nazwa A→Z</option>
                  <option value="name-desc">Nazwa Z→A</option>
                  <option value="tonnage-asc">Tonaż ↑</option>
                  <option value="tonnage-desc">Tonaż ↓</option>
                </select>
              </div>
              <div>
                <label class="text-[10px] text-hud-text-muted uppercase tracking-wider block mb-1 font-hud-heading">Max <%= @event.point_value_label %></label>
                <div class="flex items-center gap-2">
                  <input type="number" min="0"
                         data-chassis-browser-target="maxPvInput"
                         data-action="input->chassis-browser#filter"
                         class="w-20 px-2 py-1 text-xs rounded hud-select"
                         placeholder="—">
                  <label class="flex items-center gap-1.5 text-xs text-hud-text-dim cursor-pointer whitespace-nowrap"
                         title="Automatycznie ustaw limit na liczbę punktów, które pozostały do wydania">
                    <input type="checkbox"
                           data-chassis-browser-target="autoCheckbox"
                           data-action="change->chassis-browser#toggleAuto"
                           class="hud-checkbox rounded">
                    Tylko dostępne opcje wg. budżetu
                  </label>
                  <button class="hidden text-base leading-none text-hud-text-muted hover:text-hud-amber cursor-pointer px-1"
                          data-chassis-browser-target="resetButton"
                          data-action="chassis-browser#resetMaxPv"
                          title="Wyczyść filtr PV">&#10005;</button>
                </div>
              </div>
              <div>
                <label class="text-[10px] text-hud-text-muted uppercase tracking-wider block mb-1 font-hud-heading">Rola</label>
                <select data-chassis-browser-target="roleSelect"
                        data-action="change->chassis-browser#filter"
                        class="w-full px-2 py-1 text-xs rounded hud-select">
                  <option value="all">Wszystkie</option>
                </select>
              </div>
              <div>
                <label class="text-[10px] text-hud-text-muted uppercase tracking-wider block mb-1 font-hud-heading">Specjalne</label>
                <input type="text"
                       data-chassis-browser-target="abilitiesInput"
                       data-action="input->chassis-browser#filter"
                       class="w-full px-2 py-1 text-xs rounded hud-select"
                       placeholder="ENE, IF...">
              </div>
            </div>
            <div class="flex justify-end mt-2">
              <button class="text-xs text-hud-text-muted hover:text-hud-amber cursor-pointer"
                      data-action="chassis-browser#clearFilters">
                Wyczyść filtry
              </button>
            </div>
          </div>

          <div id="available_miniatures" data-view-toggle-target="container" class="items-start">
            <% faction_filter = @selected_faction_mul_ids.presence %>
            <% @chassis_data.each do |chassis, available_count, total_count| %>
              <% variants = @event.available_variants_for_chassis(chassis, tech_base: @army_list.tech_base, faction_mul_ids: faction_filter) %>
              <% next if variants.empty? && available_count > 0 %>
              <%= render partial: "chassis/available_chassis", locals: {
                chassis: chassis, available_count: available_count, total_count: total_count,
                variants: variants, event: @event, army_list: @army_list
              } %>
            <% end %>
          </div>

          <div data-chassis-browser-target="emptyState"
               class="hidden bg-hud-bg-panel border border-hud-border rounded p-6 text-center text-hud-text-muted">
            <p>Brak pasujących jednostek. Spróbuj zmienić filtry.</p>
          </div>
        </div>

        <% if @chassis_data.empty? %>
          <div class="bg-hud-bg-panel border border-hud-border rounded p-6 text-center text-hud-text-muted">
            <p>Brak dostępnych modeli.</p>
          </div>
        <% end %>
      </div>
    </div>
    </div><%# /main content wrapper %>
    </div><%# /grid %>
  <% else %>
    <%# Submitted/Inactive: army only, no tabs %>
    <div id="army_list_items" class="space-y-3 hud-dashed-divider-list">
      <% @items.each do |item| %>
        <%= render partial: "army_list_items/item",
            locals: { item: item, event: @event, army_list: @army_list, is_owner: @is_owner } %>
      <% end %>
    </div>
    <%= render partial: "army_lists/actions",
        locals: { army_list: @army_list, event: @event, is_owner: @is_owner } %>
  <% end %>
</div>

<% content_for(:toast) do %>
  <div id="toast" class="fixed top-16 left-1/2 -translate-x-1/2 z-[60]">
    <% if flash[:alert] %>
      <div class="p-4 bg-hud-bg-panel border border-hud-red text-hud-red rounded text-sm shadow-lg shadow-hud-red-glow"
           data-controller="auto-dismiss" data-auto-dismiss-delay-value="5000">
        <p><%= flash[:alert] %></p>
      </div>
      <% flash.delete(:alert) %>
    <% end %>
  </div>
<% end %>
