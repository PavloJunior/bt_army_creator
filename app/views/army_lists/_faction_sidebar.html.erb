<div class="bg-hud-bg-panel border border-hud-border rounded p-3 sticky top-4 max-h-[calc(100vh-2rem)] overflow-y-auto">
  <h3 class="text-xs text-hud-text-muted uppercase tracking-wider mb-3 font-hud-heading">Podfrakcja</h3>

  <% selected_factions = [] %>
  <% sidebar_factions.each do |_cat, factions| %>
    <% factions.each do |f| %>
      <% selected_factions << f if selected_faction_mul_ids.include?(f.mul_id) %>
    <% end %>
  <% end %>

  <% if selected_factions.any? %>
    <div class="mb-2">
      <span class="text-[10px] text-hud-text-muted uppercase tracking-wider">Wybrane</span>
      <% selected_factions.sort_by(&:name).each do |faction| %>
        <%
          remaining_ids = selected_faction_mul_ids - [faction.mul_id]
          if remaining_ids.empty?
            has_conflicts = false
          elsif army_list.army_list_items.any?
            has_conflicts = army_list.army_list_items.includes(variant: :variant_factions).any? { |item|
              item_fids = item.variant.variant_factions.map(&:faction_id)
              (item_fids & remaining_ids).empty?
            }
          else
            has_conflicts = false
          end
        %>
        <%= form_with url: toggle_faction_event_army_list_path(event, army_list),
            method: :patch,
            class: "block",
            data: { turbo: false,
                    controller: "faction-toggle",
                    faction_toggle_has_conflicts_value: has_conflicts } do |f| %>
          <%= f.hidden_field :faction_mul_id, value: faction.mul_id %>
          <button type="submit"
                  data-action="faction-toggle#toggle"
                  class="w-full text-left px-2 py-1 text-sm rounded transition block cursor-pointer
                         text-hud-green bg-hud-green/10 border border-hud-green/40">
            <%= faction.name %>
          </button>
        <% end %>
      <% end %>
    </div>

    <%= button_to toggle_faction_event_army_list_path(event, army_list),
        method: :patch,
        params: { clear_all: "true" },
        class: "w-full text-left px-2 py-1 text-xs rounded transition block mb-2
               text-hud-text-muted hover:text-hud-green hover:bg-hud-bg-panel-hover cursor-pointer",
        form: { data: { turbo: false } } do %>
      Wyczyść filtr
    <% end %>
    <div class="border-b border-hud-border mb-2"></div>
  <% end %>

  <% sidebar_factions.each do |category, factions| %>
    <% unselected = factions.reject { |f| selected_faction_mul_ids.include?(f.mul_id) } %>
    <% next if unselected.empty? %>
    <div class="mt-3 first:mt-0">
      <span class="text-[10px] text-hud-text-muted uppercase tracking-wider"><%= category %></span>
      <% unselected.each do |faction| %>
        <%= form_with url: toggle_faction_event_army_list_path(event, army_list),
            method: :patch,
            class: "block",
            data: { turbo: false,
                    controller: "faction-toggle",
                    faction_toggle_has_conflicts_value: false } do |f| %>
          <%= f.hidden_field :faction_mul_id, value: faction.mul_id %>
          <button type="submit"
                  data-action="faction-toggle#toggle"
                  class="w-full text-left px-2 py-1 text-sm rounded transition block cursor-pointer
                         text-hud-text-dim hover:text-hud-green hover:bg-hud-bg-panel-hover border border-transparent">
            <%= faction.name %>
          </button>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
