<%= link_to event_path(event), class: "block bg-white rounded-lg shadow hover:shadow-md transition p-6" do %>
  <div class="flex justify-between items-start">
    <div>
      <h3 class="text-lg font-semibold text-gray-900"><%= event.name %></h3>
      <p class="text-sm text-gray-500 mt-1">
        <%= I18n.l(event.date, format: :long) %>
      </p>
    </div>
    <div class="text-right">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-medium
        <%= active ? 'bg-green-100 text-green-800' : 'bg-blue-100 text-blue-800' %>">
        <%= active ? "Aktywne" : "Nadchodzące" %>
      </span>
    </div>
  </div>
  <div class="mt-3 flex gap-4 text-sm text-gray-600">
    <span><%= event.game_system_label %></span>
    <span>limit <%= event.point_cap %> <%= event.point_value_label %></span>
    <span><%= event.army_lists.where(status: "submitted").count %> zgłoszonych list</span>
  </div>
  <% if event.event_era_restrictions.any? %>
    <p class="mt-2 text-xs text-gray-500">
      Ery: <%= event.event_era_restrictions.map(&:era_name).join(", ") %>
    </p>
  <% end %>
<% end %>
