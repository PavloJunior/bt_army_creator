<%= link_to event_path(event),
    class: "block bg-hud-bg-panel border border-hud-border rounded p-5 hover:bg-hud-bg-panel-hover hover:border-hud-border-bright transition no-underline group hud-riveted #{active ? 'hud-accent-green' : 'hud-accent-amber'}" do %>
  <div class="flex justify-between items-start">
    <h3 class="font-hud-heading text-lg font-semibold text-hud-green group-hover:hud-glow">
      <%= event.name %>
    </h3>
    <span class="hud-stamp <%= active ? 'hud-stamp-green' : 'hud-stamp-amber' %>">
      <%= active ? "Aktywne" : "Nadchodzące" %>
    </span>
  </div>
  <div class="mt-3 grid grid-cols-2 gap-x-6 gap-y-1 text-sm">
    <div><span class="text-hud-text-muted">Data:</span> <span class="text-hud-text-dim"><%= I18n.l(event.date, format: :long) %></span></div>
    <div><span class="text-hud-text-muted">System:</span> <span class="text-hud-text-dim"><%= event.game_system_label %></span></div>
    <div><span class="text-hud-text-muted">Limit:</span> <span class="text-hud-text-dim"><%= event.point_cap %> <%= event.point_value_label %></span></div>
    <div><span class="text-hud-text-muted">Listy:</span> <span class="text-hud-text-dim"><%= event.army_lists.where(status: "submitted").count %> zgłoszonych</span></div>
  </div>
  <% if local_assigns[:has_draft] && has_draft %>
    <p class="mt-2 text-xs text-hud-amber flex items-center gap-1">
      <span class="inline-block w-1.5 h-1.5 bg-hud-amber rounded-full animate-pulse"></span>
      Masz wersję roboczą
    </p>
  <% end %>
  <% if event.event_era_restrictions.any? %>
    <p class="mt-2 text-xs text-hud-text-muted">
      Ery: <%= event.event_era_restrictions.map(&:era_name).join(", ") %>
    </p>
  <% end %>
<% end %>
