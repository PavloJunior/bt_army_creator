<div class="max-w-4xl mx-auto">
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <div class="flex justify-between items-start">
      <div>
        <h1 class="text-2xl font-bold text-gray-900"><%= @event.name %></h1>
        <p class="text-gray-500 mt-1">
          <%= I18n.l(@event.date, format: :long) %> &middot;
          <%= @event.game_system_label %> &middot;
          limit <%= @event.point_cap %> <%= @event.point_value_label %>
        </p>
      </div>
      <span class="px-3 py-1 rounded-full text-xs font-medium
        <%= case @event.status
            when 'upcoming' then 'bg-blue-100 text-blue-800'
            when 'active' then 'bg-green-100 text-green-800'
            when 'completed' then 'bg-gray-100 text-gray-800'
            end %>">
        <%= { "upcoming" => "Nadchodzące", "active" => "Aktywne", "completed" => "Zakończone" }[@event.status] %>
      </span>
    </div>

    <% if @event.event_era_restrictions.any? || @event.event_faction_restrictions.any? %>
      <div class="mt-4 pt-4 border-t border-gray-200">
        <% if @event.event_era_restrictions.any? %>
          <p class="text-sm text-gray-600">
            <span class="font-medium">Ery:</span>
            <%= @event.event_era_restrictions.map(&:era_name).join(", ") %>
          </p>
        <% end %>
        <% if @event.event_faction_restrictions.any? %>
          <p class="text-sm text-gray-600 mt-1">
            <span class="font-medium">Frakcje:</span>
            <%= @event.event_faction_restrictions.map(&:faction_name).join(", ") %>
          </p>
        <% end %>
      </div>
    <% end %>

    <% if @event.notes.present? %>
      <div class="mt-4 pt-4 border-t border-gray-200">
        <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= @event.notes %></p>
      </div>
    <% end %>
  </div>

  <% if @event.status != "completed" %>
    <div class="mb-6">
      <%= link_to "Utwórz listę armijną", new_event_army_list_path(@event),
          class: "inline-block px-6 py-3 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition" %>
    </div>
  <% end %>

  <% if @submitted_lists.any? %>
    <h2 class="text-xl font-semibold text-gray-800 mb-4">Zgłoszone listy</h2>
    <div class="space-y-3">
      <% @submitted_lists.each do |list| %>
        <%= link_to event_army_list_path(@event, list),
            class: "block bg-white rounded-lg shadow p-4 hover:shadow-md transition" do %>
          <div class="flex justify-between items-center">
            <div>
              <span class="font-medium text-gray-900"><%= list.player_name %></span>
              <span class="text-sm text-gray-500 ml-2">
                <%= list.army_list_items.size %> jednostek &middot;
                <%= list.total_points %> <%= @event.point_value_label %>
              </span>
            </div>
            <span class="text-xs text-gray-400">
              Zgłoszono <%= time_ago_in_words(list.submitted_at) %> temu
            </span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
