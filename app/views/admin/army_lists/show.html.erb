<div class="mb-6">
  <%= link_to "&larr; Back to #{@event.name}".html_safe, admin_event_path(@event),
      class: "text-hud-green hover:text-hud-green-dim text-sm" %>
</div>

<div class="flex justify-between items-start mb-6">
  <div>
    <h2 class="text-2xl font-bold text-hud-green font-hud-heading"><%= @army_list.player_name %> — Army List</h2>
    <p class="text-hud-text-muted mt-1">
      <%= @event.name %> &middot;
      <%= @army_list.tech_base_label %> &middot;
      <%= @army_list.total_points %> / <%= @army_list.effective_point_cap %> <%= @event.point_value_label %><% if @army_list.bonus_points != 0 %>
        <span class="text-hud-amber">(<%= @event.point_cap %><%= @army_list.bonus_points >= 0 ? "+" : "" %><%= @army_list.bonus_points %>)</span>
      <% end %>
    </p>
  </div>
  <span class="hud-stamp <%= case @army_list.status
        when 'submitted' then 'hud-stamp-green'
        when 'inactive' then 'hud-stamp-muted'
        else 'hud-stamp-amber'
        end %>">
    <%= { "draft" => "Draft", "submitted" => "Submitted", "inactive" => "Inactive" }[@army_list.status] %>
  </span>
</div>

<div class="bg-hud-bg-panel border border-hud-border rounded p-4 mb-6">
  <h3 class="text-sm font-medium text-hud-text-muted uppercase tracking-wider mb-2">Bonus Points</h3>
  <%= form_with model: @army_list, url: admin_event_army_list_path(@event, @army_list), method: :patch, class: "flex items-center gap-3" do |f| %>
    <%= f.number_field :bonus_points, class: "w-24 px-3 py-1.5 bg-hud-bg border border-hud-border rounded text-sm text-hud-green focus:border-hud-green focus:outline-none", step: 1 %>
    <span class="text-sm text-hud-text-muted"><%= @event.point_value_label %></span>
    <%= f.submit "Save", class: "px-3 py-1.5 hud-btn-primary rounded text-sm cursor-pointer" %>
    <% if @army_list.bonus_points != 0 %>
      <span class="text-xs text-hud-text-dim">Effective cap: <%= @army_list.effective_point_cap %> <%= @event.point_value_label %></span>
    <% end %>
  <% end %>
</div>

<% if @items.any? %>
  <div class="bg-hud-bg-panel border border-hud-border rounded overflow-hidden">
    <table class="min-w-full divide-y divide-hud-border">
      <thead class="bg-hud-bg">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-hud-text-muted uppercase">Miniature</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-hud-text-muted uppercase">Variant</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-hud-text-muted uppercase"><%= @event.point_value_label %></th>
          <th class="px-6 py-3 text-left text-xs font-medium text-hud-text-muted uppercase">Tonnage</th>
          <% if @event.game_system == "alpha_strike" %>
            <th class="px-6 py-3 text-left text-xs font-medium text-hud-text-muted uppercase">Skill</th>
          <% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-hud-border">
        <% @items.each do |item| %>
          <tr class="hover:bg-hud-bg-panel-hover">
            <td class="px-6 py-4 text-sm text-hud-green"><%= item.miniature.display_name %></td>
            <td class="px-6 py-4 text-sm text-hud-green"><%= item.variant.name %></td>
            <td class="px-6 py-4 text-sm text-hud-text-dim"><%= @event.game_system == "alpha_strike" ? item.adjusted_point_value : item.variant.battle_value || "—" %></td>
            <td class="px-6 py-4 text-sm text-hud-text-dim"><%= item.variant.tonnage || "—" %></td>
            <% if @event.game_system == "alpha_strike" %>
              <td class="px-6 py-4 text-sm text-hud-text-dim"><%= item.skill %></td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-hud-bg-panel border border-hud-border rounded p-6 text-center text-hud-text-muted">
    <p>No units on this list.</p>
  </div>
<% end %>
