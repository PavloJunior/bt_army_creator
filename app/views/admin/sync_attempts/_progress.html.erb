<%= turbo_frame_tag "sync_attempt_#{sync_attempt.id}" do %>
  <div class="flex items-center gap-3">
    <% case sync_attempt.status %>
    <% when "running" %>
      <span class="px-3 py-1 rounded-full text-xs font-medium bg-hud-amber/10 text-hud-amber border border-hud-amber/30 animate-pulse">Syncing</span>
      <span class="text-sm text-hud-text-dim"><%= sync_attempt.progress_text %></span>
    <% when "completed" %>
      <span class="px-3 py-1 rounded-full text-xs font-medium bg-hud-green/10 text-hud-green border border-hud-green/30">Completed</span>
      <span class="text-sm text-hud-text-muted"><%= time_ago_in_words(sync_attempt.completed_at) %> ago</span>
    <% when "failed" %>
      <span class="px-3 py-1 rounded-full text-xs font-medium bg-hud-red/10 text-hud-red border border-hud-red/30">Failed</span>
      <span class="text-sm text-hud-text-muted"><%= time_ago_in_words(sync_attempt.completed_at) %> ago</span>
    <% end %>
  </div>
<% end %>
