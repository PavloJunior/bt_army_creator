<%= turbo_stream_from "sync_dashboard" %>

<h2 class="text-2xl font-bold text-hud-green font-hud-heading mb-6">MUL Sync</h2>

<!-- Overview Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="bg-hud-bg-panel border border-hud-border rounded p-6 hud-panel">
    <h3 class="text-sm font-medium text-hud-text-muted uppercase tracking-wider">Total Chassis</h3>
    <p class="mt-2 text-3xl font-bold text-hud-green font-hud-heading"><%= @total_chassis %></p>
  </div>

  <div class="bg-hud-bg-panel border border-hud-border rounded p-6 hud-panel">
    <h3 class="text-sm font-medium text-hud-text-muted uppercase tracking-wider">Last Synced</h3>
    <p class="mt-2 text-3xl font-bold text-hud-green font-hud-heading">
      <%= @last_completed ? time_ago_in_words(@last_completed.completed_at) + " ago" : "Never" %>
    </p>
  </div>

  <div class="bg-hud-bg-panel border border-hud-border rounded p-6 hud-panel">
    <h3 class="text-sm font-medium text-hud-text-muted uppercase tracking-wider">Active Syncs</h3>
    <p class="mt-2 text-3xl font-bold font-hud-heading <%= @active_syncs_count > 0 ? 'text-hud-amber' : 'text-hud-green' %>">
      <%= @active_syncs_count %>
    </p>
  </div>
</div>

<!-- Chassis Sync Table -->
<% if @chassis_with_syncs.any? %>
  <div class="bg-hud-bg-panel border border-hud-border rounded overflow-hidden">
    <table class="min-w-full divide-y divide-hud-border">
      <thead class="bg-hud-bg">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-hud-text-muted uppercase tracking-wider">Chassis</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-hud-text-muted uppercase tracking-wider">Variants</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-hud-text-muted uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-hud-text-muted uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-hud-border" data-controller="variant-expand">
        <% @chassis_with_syncs.each do |chassis| %>
          <% attempt = @latest_attempts[chassis.id] %>
          <tr class="hover:bg-hud-bg-panel-hover cursor-pointer" data-action="click->variant-expand#toggle" data-variant-expand-id-param="<%= chassis.id %>">
            <td class="px-6 py-4 whitespace-nowrap font-medium">
              <span class="mr-2 text-hud-text-muted" data-variant-expand-target="arrow" data-id="<%= chassis.id %>">&#9654;</span>
              <%= link_to chassis.name, admin_chassis_path(chassis), class: "text-hud-green hover:text-hud-green-dim" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-hud-text-dim text-right"><%= chassis.variants.size %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <% if attempt %>
                <%= render "admin/sync_attempts/progress", sync_attempt: attempt %>
              <% else %>
                <span class="px-3 py-1 rounded-full text-xs font-medium bg-hud-bg border border-hud-border text-hud-text-muted">Never synced</span>
              <% end %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
              <%= button_to "Sync", sync_variants_admin_chassis_path(chassis),
                  method: :post, class: "text-hud-green hover:text-hud-green-dim font-medium",
                  data: { turbo_confirm: "Sync #{chassis.name} with MUL?" } %>
            </td>
          </tr>
          <!-- Expandable sync history -->
          <tr class="hidden" data-variant-expand-target="details" data-id="<%= chassis.id %>">
            <td colspan="4" class="px-6 py-4 bg-hud-bg">
              <% recent = @recent_attempts_by_chassis[chassis.id] || [] %>
              <% if recent.any? %>
                <h4 class="text-sm font-medium text-hud-text-dim mb-2">Recent Sync History</h4>
                <div class="space-y-2">
                  <% recent.each do |sa| %>
                    <div class="flex items-center justify-between text-sm">
                      <div class="flex items-center gap-3">
                        <% case sa.status %>
                        <% when "running" %>
                          <span class="px-2 py-0.5 rounded text-xs font-medium bg-hud-amber/10 text-hud-amber border border-hud-amber/30">Running</span>
                        <% when "completed" %>
                          <span class="px-2 py-0.5 rounded text-xs font-medium bg-hud-green/10 text-hud-green border border-hud-green/30">Completed</span>
                        <% when "failed" %>
                          <span class="px-2 py-0.5 rounded text-xs font-medium bg-hud-red/10 text-hud-red border border-hud-red/30">Failed</span>
                        <% end %>
                        <span class="text-hud-text-dim">
                          <%= sa.variants_count %> variants ·
                          <%= sa.factions_synced %>/<%= sa.factions_total %> factions ·
                          <%= sa.cards_synced %>/<%= sa.cards_total %> cards
                        </span>
                      </div>
                      <div class="text-hud-text-muted">
                        <%= sa.started_at&.strftime("%b %d, %H:%M") %>
                        <% if sa.duration %> · <%= sa.duration %>s<% end %>
                      </div>
                    </div>
                    <% if sa.error_messages.present? && sa.error_messages.any? %>
                      <div class="ml-6 text-xs text-hud-red">
                        <%= sa.error_messages.last(3).join("; ") %>
                        <% if sa.error_messages.size > 3 %>
                          <span class="text-hud-text-muted">...and <%= sa.error_messages.size - 3 %> more</span>
                        <% end %>
                      </div>
                    <% end %>
                  <% end %>
                </div>
              <% else %>
                <p class="text-sm text-hud-text-muted">No sync history for this chassis.</p>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-hud-bg-panel border border-hud-border rounded p-8 text-center text-hud-text-muted">
    <p>No chassis found. Add chassis first to start syncing.</p>
  </div>
<% end %>
