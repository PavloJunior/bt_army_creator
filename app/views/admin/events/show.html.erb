<div class="flex justify-between items-start mb-6">
  <div>
    <h2 class="text-2xl font-bold text-hud-green font-hud-heading"><%= @event.name %></h2>
    <p class="text-hud-text-muted mt-1">
      <%= I18n.l(@event.date, format: :long) %> &middot;
      <%= @event.game_system_label %> &middot;
      limit <%= @event.point_cap %> <%= @event.point_value_label %>
    </p>
  </div>
  <div class="flex items-center gap-3">
    <span class="hud-stamp <%= case @event.status
          when 'upcoming' then 'hud-stamp-green'
          when 'active' then 'hud-stamp-amber'
          when 'completed' then 'hud-stamp-muted'
          end %>">
      <%= { "upcoming" => "Upcoming", "active" => "Active", "completed" => "Completed" }[@event.status] %>
    </span>
    <% if @event.status == "upcoming" %>
      <%= button_to "Activate", activate_admin_event_path(@event), method: :patch,
          class: "px-3 py-1 hud-btn-primary rounded text-sm" %>
    <% elsif @event.status == "active" %>
      <%= button_to "Complete", complete_admin_event_path(@event), method: :patch,
          class: "px-3 py-1 hud-btn-amber rounded text-sm",
          data: { turbo_confirm: "Mark this event as completed?" } %>
    <% end %>
    <%= link_to "Edit", edit_admin_event_path(@event),
        class: "px-3 py-1 hud-btn-amber rounded text-sm" %>
  </div>
</div>

<% if @event.event_era_restrictions.any? || @event.event_faction_restrictions.any? %>
  <div class="bg-hud-bg-panel border border-hud-border rounded p-4 mb-6">
    <h3 class="text-sm font-medium text-hud-text-muted uppercase tracking-wider mb-2">Restrictions</h3>
    <% if @event.event_era_restrictions.any? %>
      <p class="text-sm text-hud-text-dim">
        <span class="font-medium text-hud-green">Eras:</span>
        <%= @event.event_era_restrictions.map(&:era_name).join(", ") %>
      </p>
    <% end %>
    <% if @event.event_faction_restrictions.any? %>
      <p class="text-sm text-hud-text-dim mt-1">
        <span class="font-medium text-hud-green">Factions:</span>
        <%= @event.event_faction_restrictions.map(&:faction_name).join(", ") %>
      </p>
    <% end %>
  </div>
<% end %>

<% if @event.notes.present? %>
  <div class="bg-hud-bg-panel border border-hud-border rounded p-4 mb-6">
    <h3 class="text-sm font-medium text-hud-text-muted uppercase tracking-wider mb-2">Notes</h3>
    <p class="text-sm text-hud-text-dim whitespace-pre-wrap"><%= @event.notes %></p>
  </div>
<% end %>

<h3 class="text-lg font-semibold text-hud-green mb-4">Army Lists (<%= @army_lists.size %>)</h3>

<% if @army_lists.any? %>
  <div class="space-y-3">
    <% @army_lists.each do |list| %>
      <div class="bg-hud-bg-panel border border-hud-border rounded p-4 flex justify-between items-center">
        <div>
          <span class="font-medium text-hud-green"><%= list.player_name %></span>
          <span class="text-sm text-hud-text-muted ml-2">
            <%= list.army_list_items.size %> units &middot;
            <%= list.total_points %> <%= @event.point_value_label %>
          </span>
          <span class="ml-2 hud-stamp <%= list.submitted? ? 'hud-stamp-green' : 'hud-stamp-amber' %>">
            <%= { "draft" => "Draft", "submitted" => "Submitted" }[list.status] %>
          </span>
        </div>
        <div class="flex gap-2">
          <%= link_to "View", admin_event_army_list_path(@event, list),
              class: "text-hud-green hover:text-hud-green-dim text-sm" %>
          <% if list.submitted? %>
            <%= button_to "Unlock", unlock_admin_event_army_list_path(@event, list),
                method: :patch, class: "text-hud-amber hover:text-hud-amber-dim text-sm",
                data: { turbo_confirm: "Unlock this list? Miniatures will be released." } %>
          <% end %>
          <%= button_to "Delete", admin_event_army_list_path(@event, list),
              method: :delete, class: "text-hud-red hover:text-hud-red-dim text-sm",
              data: { turbo_confirm: "Delete this army list?" } %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-hud-bg-panel border border-hud-border rounded p-6 text-center text-hud-text-muted">
    <p>No army lists for this event.</p>
  </div>
<% end %>
