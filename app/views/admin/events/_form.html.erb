<%= form_with model: [:admin, event], class: "space-y-6" do |form| %>
  <% if event.errors.any? %>
    <div class="p-4 bg-red-100 border border-red-300 text-red-800 rounded-lg">
      <ul class="list-disc list-inside">
        <% event.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name, required: true, autofocus: true,
          class: "w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= form.label :date, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.date_field :date, required: true,
          class: "w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= form.label :game_system, "Game System", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.select :game_system,
          [["Alpha Strike", "alpha_strike"], ["Classic BattleTech", "classic_bt"]],
          {}, class: "w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= form.label :point_cap, "Point Cap", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.number_field :point_cap, required: true, min: 1,
          class: "w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  </div>

  <div>
    <%= form.label :notes, "Additional Rules / Notes", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :notes, rows: 4,
        placeholder: "Additional rules or notes for this event...",
        class: "w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <% if eras.any? %>
    <fieldset>
      <legend class="text-sm font-medium text-gray-700 mb-2">Era restrictions (leave empty for no restriction)</legend>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
        <% eras.each do |era| %>
          <label class="flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="era_ids[]" value="<%= era.mul_id %>"
                   <%= "checked" if event.event_era_restrictions.any? { |r| r.era_mul_id == era.mul_id } %>
                   class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
            <%= era.name %>
          </label>
        <% end %>
      </div>
    </fieldset>
  <% end %>

  <% if factions.any? %>
    <fieldset>
      <legend class="text-sm font-medium text-gray-700 mb-2">Faction restrictions (leave empty for no restriction)</legend>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-2 max-h-64 overflow-y-auto border border-gray-200 rounded-lg p-3">
        <% factions.each do |faction| %>
          <label class="flex items-center gap-2 text-sm text-gray-700">
            <input type="checkbox" name="faction_ids[]" value="<%= faction.mul_id %>"
                   <%= "checked" if event.event_faction_restrictions.any? { |r| r.faction_mul_id == faction.mul_id } %>
                   class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
            <%= faction.name %>
          </label>
        <% end %>
      </div>
    </fieldset>
  <% end %>

  <div class="flex gap-3">
    <%= form.submit class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition cursor-pointer" %>
    <%= link_to "Cancel", admin_events_path,
        class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition" %>
  </div>
<% end %>
