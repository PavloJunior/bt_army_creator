<div class="flex justify-between items-center mb-6">
  <h2 class="text-2xl font-bold text-gray-900">Events</h2>
  <%= link_to "Create Event", new_admin_event_path,
      class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition" %>
</div>

<% if @events.any? %>
  <div class="space-y-4">
    <% @events.each do |event| %>
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-lg font-semibold text-gray-900">
              <%= link_to event.name, admin_event_path(event), class: "hover:text-blue-600" %>
            </h3>
            <p class="text-sm text-gray-500 mt-1">
              <%= I18n.l(event.date, format: :long) %> &middot;
              <%= event.game_system_label %> &middot;
              limit <%= event.point_cap %> <%= event.point_value_label %>
            </p>
          </div>
          <span class="px-3 py-1 rounded-full text-xs font-medium
            <%= case event.status
                when 'upcoming' then 'bg-blue-100 text-blue-800'
                when 'active' then 'bg-green-100 text-green-800'
                when 'completed' then 'bg-gray-100 text-gray-800'
                end %>">
            <%= { "upcoming" => "Upcoming", "active" => "Active", "completed" => "Completed" }[event.status] %>
          </span>
        </div>
        <div class="mt-3 flex gap-3 text-sm">
          <%= link_to "View", admin_event_path(event), class: "text-blue-600 hover:text-blue-800" %>
          <%= link_to "Edit", edit_admin_event_path(event), class: "text-indigo-600 hover:text-indigo-800" %>
          <%= button_to "Delete", admin_event_path(event), method: :delete,
              class: "text-red-600 hover:text-red-800",
              data: { turbo_confirm: "Delete this event?" } %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white rounded-lg shadow p-8 text-center text-gray-500">
    <p>No events. Create the first one to get started.</p>
  </div>
<% end %>
