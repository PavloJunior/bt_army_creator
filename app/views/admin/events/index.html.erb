<div class="flex justify-between items-center mb-6">
  <h2 class="text-2xl font-bold text-hud-green font-hud-heading">Events</h2>
  <%= link_to "Create Event", new_admin_event_path,
      class: "px-4 py-2 hud-btn-primary rounded" %>
</div>

<% if @events.any? %>
  <div class="space-y-4">
    <% @events.each do |event| %>
      <div class="bg-hud-bg-panel border border-hud-border rounded p-6 hud-panel">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="text-lg font-semibold">
              <%= link_to event.name, admin_event_path(event), class: "text-hud-green hover:text-hud-green-dim" %>
            </h3>
            <p class="text-sm text-hud-text-muted mt-1">
              <%= I18n.l(event.date, format: :long) %> &middot;
              <%= event.game_system_label %> &middot;
              limit <%= event.point_cap %> <%= event.point_value_label %>
            </p>
          </div>
          <span class="px-3 py-1 rounded-full text-xs font-medium
            <%= case event.status
                when 'upcoming' then 'bg-hud-green/10 text-hud-green border border-hud-green/30'
                when 'active' then 'bg-hud-amber/10 text-hud-amber border border-hud-amber/30'
                when 'completed' then 'bg-hud-bg border border-hud-border text-hud-text-muted'
                end %>">
            <%= { "upcoming" => "Upcoming", "active" => "Active", "completed" => "Completed" }[event.status] %>
          </span>
        </div>
        <div class="mt-3 flex gap-3 text-sm">
          <%= link_to "View", admin_event_path(event), class: "text-hud-green hover:text-hud-green-dim" %>
          <%= link_to "Edit", edit_admin_event_path(event), class: "text-hud-amber hover:text-hud-amber-dim" %>
          <%= button_to "Delete", admin_event_path(event), method: :delete,
              class: "text-hud-red hover:text-hud-red-dim",
              data: { turbo_confirm: "Delete this event?" } %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-hud-bg-panel border border-hud-border rounded p-8 text-center text-hud-text-muted">
    <p>No events. Create the first one to get started.</p>
  </div>
<% end %>
