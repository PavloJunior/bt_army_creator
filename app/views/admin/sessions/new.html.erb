<div class="flex items-center justify-center min-h-screen -m-8">
  <div class="w-full max-w-md">
    <div class="bg-hud-bg-panel border border-hud-border-bright rounded p-8 hud-panel">
      <h2 class="text-2xl font-bold text-hud-green font-hud-heading hud-glow mb-6 text-center">Admin Login</h2>

      <% if flash[:alert] %>
        <div class="mb-4 p-3 bg-hud-red/10 border border-hud-red text-hud-red rounded text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: admin_session_path, class: "space-y-4" do |form| %>
        <div>
          <%= form.label :email_address, "Email", class: "block text-sm font-medium text-hud-text-dim mb-1" %>
          <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email",
              class: "w-full px-3 py-2 hud-input rounded" %>
        </div>

        <div>
          <%= form.label :password, "Password", class: "block text-sm font-medium text-hud-text-dim mb-1" %>
          <%= form.password_field :password, required: true, autocomplete: "current-password",
              class: "w-full px-3 py-2 hud-input rounded" %>
        </div>

        <%= form.submit "Sign In",
            class: "w-full py-2 px-4 hud-btn-primary rounded cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>
