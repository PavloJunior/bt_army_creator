<h2 class="text-2xl font-bold text-hud-green font-hud-heading mb-6">Bulk Add Miniatures for <%= @chassis.name %></h2>

<div class="max-w-lg bg-hud-bg-panel border border-hud-border rounded p-6">
  <%= form_with url: bulk_create_admin_chassis_miniatures_path(@chassis), method: :post, class: "space-y-4" do |form| %>
    <div>
      <%= form.label :count, "How many?", class: "block text-sm font-medium text-hud-text-dim mb-1" %>
      <%= form.number_field :count, value: 1, min: 1, max: 100, autofocus: true,
          class: "w-full px-3 py-2 hud-input hud-number-input rounded" %>
    </div>

    <div class="flex gap-3">
      <%= form.submit "Add Miniatures",
          class: "px-4 py-2 hud-btn-primary rounded cursor-pointer" %>
      <%= link_to "Cancel", admin_chassis_path(@chassis),
          class: "px-4 py-2 hud-btn-danger rounded" %>
    </div>
  <% end %>
</div>
