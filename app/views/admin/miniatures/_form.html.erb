<%= form_with model: [:admin, chassis, miniature], class: "space-y-4" do |form| %>
  <% if miniature.errors.any? %>
    <div class="p-4 bg-hud-red/10 border border-hud-red text-hud-red rounded">
      <ul class="list-disc list-inside">
        <% miniature.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :label, "Label (optional)", class: "block text-sm font-medium text-hud-text-dim mb-1" %>
    <%= form.text_field :label, autofocus: true,
        placeholder: "e.g. Atlas #2, red, proxy",
        class: "w-full px-3 py-2 hud-input rounded" %>
    <p class="mt-1 text-sm text-hud-text-muted">Optional label to distinguish multiple miniatures of the same chassis</p>
  </div>

  <div>
    <%= form.label :notes, "Notes (optional)", class: "block text-sm font-medium text-hud-text-dim mb-1" %>
    <%= form.text_area :notes, rows: 3,
        placeholder: "Any notes about this miniature...",
        class: "w-full px-3 py-2 hud-input rounded" %>
  </div>

  <div class="flex gap-3">
    <%= form.submit class: "px-4 py-2 hud-btn-primary rounded cursor-pointer" %>
    <%= link_to "Cancel", admin_chassis_index_path,
        class: "px-4 py-2 hud-btn-danger rounded" %>
  </div>
<% end %>
