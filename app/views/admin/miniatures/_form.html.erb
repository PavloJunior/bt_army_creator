<%= form_with model: [:admin, chassis, miniature], class: "space-y-4" do |form| %>
  <% if miniature.errors.any? %>
    <div class="p-4 bg-red-100 border border-red-300 text-red-800 rounded-lg">
      <ul class="list-disc list-inside">
        <% miniature.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :label, "Label (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :label, autofocus: true,
        placeholder: "e.g. Atlas #2, red, proxy",
        class: "w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    <p class="mt-1 text-sm text-gray-500">Optional label to distinguish multiple miniatures of the same chassis</p>
  </div>

  <div>
    <%= form.label :notes, "Notes (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_area :notes, rows: 3,
        placeholder: "Any notes about this miniature...",
        class: "w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="flex gap-3">
    <%= form.submit class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition cursor-pointer" %>
    <%= link_to "Cancel", admin_chassis_index_path,
        class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition" %>
  </div>
<% end %>
