<%= form_with model: [:admin, chassis], class: "space-y-4" do |form| %>
  <% if chassis.errors.any? %>
    <div class="p-4 bg-hud-red/10 border border-hud-red text-hud-red rounded">
      <ul class="list-disc list-inside">
        <% chassis.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Chassis Name", class: "block text-sm font-medium text-hud-text-dim mb-1" %>
    <%= form.text_field :name, required: true, autofocus: true,
        placeholder: "e.g. Atlas, Timber Wolf, Commando",
        class: "w-full px-3 py-2 hud-input rounded" %>
    <p class="mt-1 text-sm text-hud-text-muted">Enter the chassis name exactly as it appears on masterunitlist.info</p>
  </div>

  <div>
    <%= form.label :unit_type, "Unit Type", class: "block text-sm font-medium text-hud-text-dim mb-1" %>
    <%= form.select :unit_type,
        options_for_select(Chassis::UNIT_TYPES, chassis.unit_type),
        { include_blank: "— Select unit type —" },
        class: "w-full px-3 py-2 hud-input rounded" %>
    <p class="mt-1 text-sm text-hud-text-muted">Usually set automatically during MUL sync</p>
  </div>

  <div class="flex gap-3">
    <%= form.submit class: "px-4 py-2 hud-btn-primary rounded cursor-pointer" %>
    <%= link_to "Cancel", admin_chassis_index_path,
        class: "px-4 py-2 hud-btn-danger rounded" %>
  </div>
<% end %>
