<div class="flex justify-between items-center mb-6">
  <h2 class="text-2xl font-bold text-hud-green font-hud-heading">Chassis</h2>
  <%= link_to "Add Chassis", new_admin_chassis_path,
      class: "px-4 py-2 hud-btn-primary rounded" %>
</div>

<% if @chassis.any? %>
  <div class="bg-hud-bg-panel border border-hud-border rounded overflow-hidden">
    <table class="min-w-full divide-y divide-hud-border">
      <thead class="bg-hud-bg">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-hud-text-muted uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-hud-text-muted uppercase tracking-wider">Type</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-hud-text-muted uppercase tracking-wider">Tonnage</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-hud-text-muted uppercase tracking-wider">Variants</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-hud-text-muted uppercase tracking-wider">Miniatures</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-hud-text-muted uppercase tracking-wider">Last Sync</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-hud-text-muted uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-hud-border">
        <% @chassis.each do |chassis| %>
          <tr class="hover:bg-hud-bg-panel-hover">
            <td class="px-6 py-4 whitespace-nowrap font-medium">
              <%= link_to chassis.name, admin_chassis_path(chassis),
                  class: "text-hud-green hover:text-hud-green-dim" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-hud-text-dim"><%= chassis.unit_type || "—" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-hud-text-dim text-right"><%= chassis.tonnage || "—" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-hud-text-dim text-right"><%= chassis.variants.size %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-hud-text-dim text-right"><%= @mini_pool_sizes[chassis.id] %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-hud-text-dim">
              <%= chassis.mul_synced_at ? time_ago_in_words(chassis.mul_synced_at) + " ago" : "Never" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
              <%= button_to "Sync", sync_variants_admin_chassis_path(chassis),
                  method: :post, class: "text-hud-green hover:text-hud-green-dim" %>
              <%= link_to "Edit", edit_admin_chassis_path(chassis),
                  class: "text-hud-amber hover:text-hud-amber-dim" %>
              <%= button_to "Delete", admin_chassis_path(chassis),
                  method: :delete, class: "text-hud-red hover:text-hud-red-dim",
                  data: { turbo_confirm: "Delete #{chassis.name} and all variants?" } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="bg-hud-bg-panel border border-hud-border rounded p-8 text-center text-hud-text-muted">
    <p>No chassis found. Add the first one to start building the miniature inventory.</p>
  </div>
<% end %>
