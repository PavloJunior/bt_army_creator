<div id="<%= dom_id(item) %>" class="bg-white rounded-lg shadow p-4">
  <div class="flex justify-between items-center">
    <div>
      <span class="font-medium text-gray-900"><%= item.variant.name %></span>
      <% if item.miniature.label.present? %>
        <span class="text-xs text-gray-400 ml-1">(<%= item.miniature.label %>)</span>
      <% end %>
      <div class="text-sm text-gray-500 mt-0.5">
        <%= item.variant.tonnage %>t &middot;
        <%= event.game_system == "alpha_strike" ? item.adjusted_point_value : item.variant.battle_value %> <%= event.point_value_label %> &middot;
        <%= item.variant.role || "Nieznana" %>
        <% if event.game_system == "alpha_strike" %>
          &middot; Skill: <%= item.skill %>
        <% end %>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <% if is_owner && army_list.draft? && event.game_system == "alpha_strike" %>
        <%= form_with model: [event, army_list, item],
            class: "flex items-center gap-1",
            data: { controller: "skill-select" } do |f| %>
          <label class="text-xs text-gray-500">Skill:</label>
          <%= f.select :skill, (0..8).to_a,
              { selected: item.skill },
              class: "px-2 py-1 text-sm border border-gray-300 rounded",
              data: { action: "change->skill-select#submit" } %>
        <% end %>
      <% end %>
      <% if is_owner && army_list.draft? %>
        <%= button_to "Usuń",
            event_army_list_army_list_item_path(event, army_list, item),
            method: :delete,
            class: "text-red-500 hover:text-red-700 text-sm",
            data: { turbo_confirm: "Usunąć tę jednostkę?" } %>
      <% end %>
    </div>
  </div>

  <% if event.game_system == "alpha_strike" %>
    <div id="<%= dom_id(item, :card) %>" class="mt-3">
      <% variant_card = item.variant.card_for_skill(item.skill) %>
      <% if variant_card&.image&.attached? %>
        <%= image_tag variant_card.image, class: "w-full rounded border border-gray-200",
            alt: "Karta #{item.variant.name} (Skill #{item.skill})" %>
      <% else %>
        <div class="bg-gray-100 rounded p-4 text-center text-sm text-gray-400"
             data-controller="card-loader"
             data-card-loader-url-value="<%= card_variant_path(item.variant, skill: item.skill) %>"
             data-card-loader-item-id-value="<%= dom_id(item, :card) %>">
          <p>Pobieranie karty...</p>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
