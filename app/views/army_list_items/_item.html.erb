<div id="<%= dom_id(item) %>"
     class="bg-hud-bg-panel border border-hud-border rounded p-4 hud-accent-green">
  <div class="flex justify-between items-start">
    <div class="flex-1">
      <span class="font-hud-heading font-semibold text-hud-green text-lg"><%= item.variant.name %></span>
      <% if item.miniature.label.present? %>
        <span class="text-xs text-hud-text-muted ml-1">(<%= item.miniature.label %>)</span>
      <% end %>
      <div class="mt-1 flex flex-wrap gap-x-4 gap-y-1 text-sm">
        <div class="hud-dim-item">
          <span class="hud-dim-label">Tonaż</span>
          <span class="hud-dim-line"></span>
          <span class="hud-dim-value"><%= item.variant.tonnage %>t</span>
        </div>
        <div class="hud-dim-item">
          <span class="hud-dim-label"><%= event.point_value_label %></span>
          <span class="hud-dim-line"></span>
          <span class="hud-dim-value"><%= event.game_system == "alpha_strike" ? item.adjusted_point_value : item.variant.battle_value %></span>
        </div>
        <div class="hud-dim-item">
          <span class="hud-dim-label">Rola</span>
          <span class="hud-dim-line"></span>
          <span class="hud-dim-value"><%= item.variant.role || "Nieznana" %></span>
        </div>
        <% if event.game_system == "alpha_strike" %>
          <div class="hud-dim-item">
            <span class="hud-dim-label">Skill</span>
            <span class="hud-dim-line"></span>
            <span class="hud-dim-value"><%= item.skill %></span>
          </div>
        <% end %>
      </div>
    </div>
    <div class="flex items-center gap-2 ml-4">
      <% if is_owner && army_list.draft? && event.game_system == "alpha_strike" %>
        <%= form_with model: [event, army_list, item],
            class: "flex items-center gap-1",
            data: { controller: "skill-select" } do |f| %>
          <label class="text-xs text-hud-text-muted uppercase">Skill:</label>
          <%= f.select :skill, (0..8).to_a,
              { selected: item.skill },
              class: "px-2 py-1 text-sm rounded hud-select",
              data: { action: "change->skill-select#submit" } %>
        <% end %>
      <% end %>
      <% if is_owner && army_list.draft? %>
        <%= button_to "Usuń",
            event_army_list_army_list_item_path(event, army_list, item),
            method: :delete,
            class: "hud-btn-danger px-3 py-1 rounded text-xs cursor-pointer",
            form: { data: {
              controller: "confirm-modal",
              confirm_modal_title_value: "Usuń jednostkę",
              confirm_modal_message_value: "Usunąć <span class='text-hud-amber'>#{item.variant.name}</span> z listy?",
              confirm_modal_confirm_value: "Usuń",
              confirm_modal_cancel_value: "Anuluj"
            } },
            data: { action: "click->confirm-modal#show" } %>
      <% end %>
    </div>
  </div>

  <% if event.game_system == "alpha_strike" && item.variant.bf_abilities.present? %>
    <div class="mt-2 flex flex-wrap items-center gap-1" data-controller="special-ability-modal">
      <span class="text-hud-text-muted text-xs mr-1">Special:</span>
      <%= render_ability_buttons(item.variant.bf_abilities) %>
    </div>
  <% end %>

  <% if event.game_system == "alpha_strike" %>
    <details class="mt-3"
            data-controller="card-toggle"
            data-card-toggle-key-value="<%= dom_id(item, :card_open) %>"
            data-action="toggle->card-toggle#toggle">
      <summary class="text-xs text-hud-text-muted cursor-pointer hover:text-hud-green select-none uppercase tracking-wider">
        Pokaż kartę ▸
      </summary>
      <div id="<%= dom_id(item, :card) %>" class="mt-2">
        <% variant_card = item.variant.card_for_skill(item.skill) %>
        <% if variant_card&.image&.attached? %>
          <%= image_tag variant_card.image,
              class: "w-full rounded border border-hud-border",
              alt: "Karta #{item.variant.name} (Skill #{item.skill})" %>
        <% else %>
          <div class="bg-hud-bg rounded p-4 text-center text-sm text-hud-text-muted border border-hud-border"
               data-controller="card-loader"
               data-card-loader-url-value="<%= card_variant_path(item.variant, skill: item.skill) %>"
               data-card-loader-item-id-value="<%= dom_id(item, :card) %>">
            <p>Pobieranie karty...</p>
          </div>
        <% end %>
      </div>
    </details>
  <% end %>
</div>
