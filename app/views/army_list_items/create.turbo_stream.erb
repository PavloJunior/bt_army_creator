<%= turbo_stream.append "army_list_items" do %>
  <%= render partial: "army_list_items/item",
      locals: { item: @item, event: @event, army_list: @army_list, is_owner: true } %>
<% end %>

<%= turbo_stream.replace "point_total" do %>
  <%= render partial: "army_lists/point_total",
      locals: { army_list: @army_list.reload, event: @event } %>
<% end %>

<%= turbo_stream.replace "available_chassis_#{@chassis.id}" do %>
  <%= render partial: "chassis/available_chassis", locals: {
    chassis: @chassis, available_count: @available_count, total_count: @total_count,
    variants: @variants, event: @event, army_list: @army_list
  } %>
<% end %>

<% @sibling_chassis_data&.each do |sibling_data| %>
  <%= turbo_stream.replace "available_chassis_#{sibling_data[:chassis].id}" do %>
    <%= render partial: "chassis/available_chassis", locals: {
      chassis: sibling_data[:chassis], available_count: sibling_data[:available_count],
      total_count: sibling_data[:total_count], variants: sibling_data[:variants],
      event: @event, army_list: @army_list
    } %>
  <% end %>
<% end %>

<%= turbo_stream.remove "army_list_empty_state" %>

<% if @over_cap %>
  <%= turbo_stream.update "toast" do %>
    <div class="p-4 bg-hud-bg-panel border border-hud-amber text-hud-amber rounded text-sm shadow-lg shadow-hud-amber-glow"
         data-controller="auto-dismiss" data-auto-dismiss-delay-value="4000">
      <p>Przekroczono limit <%= @army_list.effective_point_cap %> <%= @event.point_value_label %> — nie będzie można zgłosić listy bez zmniejszenia punktów.</p>
    </div>
  <% end %>
<% else %>
  <%= turbo_stream.update "toast", "" %>
<% end %>

<%= turbo_stream.update "army_item_count", @army_list.army_list_items.size.to_s %>

<%= turbo_stream.replace "army_list_actions" do %>
  <%= render partial: "army_lists/actions",
      locals: { army_list: @army_list, event: @event, is_owner: true } %>
<% end %>
